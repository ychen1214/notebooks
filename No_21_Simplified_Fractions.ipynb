   "source": [
    "from fractions import Fraction\n",
    "def is_whole(f):\n",
    "    return f.denominator == 1\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "e36a9e3a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1/4 is a fraction\n"
     ]
    }
   ],
   "source": [
    "f2 = Fraction(100, 400)\n",
    "if is_whole(f2):\n",
    "    print(f\"{f2.numerator} is a whole number\")\n",
    "else:\n",
    "    print(f\"{f2} is a fraction\")"
   ]
  }
 ],
