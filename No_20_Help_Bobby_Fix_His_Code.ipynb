   "source": [
    "#Help Bobby Fix His Code\n",
    "def help_bobby(size):      \n",
    "    row=0    \n",
    "    list =[]    \n",
    "    for column in range(size):\n",
    "        array=[[0]*size]\n",
    "        array[row][column]=1        \n",
    "        list.append(array)                \n",
    "    return list"
   ]
  },
